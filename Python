library = []

while True:
    print("\n----- LibSpace Library System -----")
    print("1. Add Book")
    print("2. View Books")
    print("3. Search Book")
    print("4. Delete Book")
    print("5. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        title = input("Enter book title: ")
        author = input("Enter author name: ")
        library.append((title, author))
        print("Book added successfully!")

    elif choice == "2":
        print("\nLibrary Books:")
        for book in library:
            print("Title:", book[0], "| Author:", book[1])

    elif choice == "3":
        search = input("Enter book title to search: ")
        found = False
        for book in library:
            if book[0] == search:
                print("Book Found:", book[0], "-", book[1])
                found = True
        if not found:
            print("Book not found")

    elif choice == "4":
        delete = input("Enter book title to delete: ")
        for book in library:
            if book[0] == delete:
                library.remove(book)
                print("Book deleted successfully!")
                break

    elif choice == "5":
        print("Exiting LibSpace...")
        break

    else:
        print("Invalid choice")
